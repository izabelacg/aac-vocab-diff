vocab-description.md
*.pdf
tmp/

# Go build output
bin/

# macOS metadata
.DS_Store

# CI secrets — never commit real credentials
ci/secrets.yaml

# Reference snapshots and private notes — not part of the module
_plans/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
requirements-dev.txt